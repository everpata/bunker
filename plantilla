<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Deepfall / Lección</title>
    <style>
        /* ESTILO GENERAL (No tocar) */
        * { margin: 0; padding: 0; box-sizing: border-box; }
        html, body { width: 100%; min-height: 100%; background-color: #ffffff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; display: flex; justify-content: center; }
        .container { width: 100%; max-width: 460px; padding: 60px 45px; display: flex; flex-direction: column; align-items: flex-start; }
        .logo { margin: 0 0 30px -10px; }
        .logo img { height: 60px; width: auto; display: block; }
        .indicator { font-size: 11px; font-weight: 600; color: #878787; margin-bottom: 12px; letter-spacing: 1.5px; text-transform: uppercase; }
        .title { font-size: 30px; font-weight: 700; color: #333333; margin-bottom: 16px; line-height: 1.1; letter-spacing: -0.8px; }
        .description { font-size: 16px; color: #878787; margin-bottom: 32px; line-height: 1.5; }
        
        /* BOTÓN PRINCIPAL */
        .btn-mando { width: 100%; background: #333333; color: #ffffff; border: none; padding: 20px; border-radius: 14px; font-size: 16px; font-weight: 500; cursor: pointer; text-decoration: none; display: block; text-align: center; }
        
        /* BLOQUE DE CONVERSIÓN (Invisible por defecto) */
        #conversion-upgrade { display: none; margin-top: 50px; padding-top: 40px; border-top: 1px solid #f0f0f0; width: 100%; }
        
        @media (max-width: 480px) { .container { padding: 40px 30px; } .title { font-size: 26px; } }
    </style>
</head>
<body>

    <div class="container">
        <div class="logo"><img src="../deepmersion.jpeg" alt="logo"></div>
        
        <p class="indicator">Tramo 01 / Lección</p>
        
        <h1 class="title">Escribe aquí el título de la lección.</h1>
        
        <div class="description">
            <p>Aquí escribes el texto de tu lección. Si quieres poner un video de YouTube, solo pega el código que te da YouTube aquí mismo.</p>
        </div>

        <a href="m_2.html" id="next-btn" class="btn-mando">Continuar expedición &#8594;</a>

        <div id="conversion-upgrade">
            <p class="indicator">Estatus: Fundamentos Dominados</p>
            <h2 class="title" style="font-size: 24px; margin-bottom: 12px;">¿Listo para el siguiente nivel?</h2>
            <p class="description" style="font-size: 14px; margin-bottom: 25px;">Ya dominas estos protocolos. La verdadera expedición operativa te espera en el Tramo 02.</p>
            <a href="../hub.html" class="btn-mando">Avanzar al Tramo 02 &#8594;</a>
        </div>
    </div>

    <script src="https://www.gstatic.com/firebasejs/9.15.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.15.0/firebase-auth-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.15.0/firebase-firestore-compat.js"></script>

    <script>
        const firebaseConfig = {
            apiKey: "AIzaSyARmU6NUnRajN8dMB6Pi35WbSC2ZKJd-X8",
            authDomain: "deepfall-b3601.firebaseapp.com",
            projectId: "deepfall-b3601",
            storageBucket: "deepfall-b3601.firebasestorage.app",
            messagingSenderId: "207043962011",
            appId: "1:207043962011:web:681397c7d540b4b3d4523e"
        };
        firebase.initializeApp(firebaseConfig);
        const auth = firebase.auth();
        const db = firebase.firestore();

        auth.onAuthStateChanged((user) => {
            if (user) {
                db.collection("usuarios").doc(user.uid).get().then((doc) => {
                    if (doc.exists) {
                        const data = doc.data();
                        // Si ya terminó el programa completo y no ha pagado el siguiente
                        if (data.fase === "Finalizado" && !data.access_DM) {
                            document.getElementById('conversion-upgrade').style.display = 'block';
                            document.getElementById('next-btn').style.display = 'none';
                        }
                    }
                });
            } else {
                window.location.href = "../index.html";
            }
        });
    </script>
</body>
</html>
